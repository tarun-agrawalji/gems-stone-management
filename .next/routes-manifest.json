        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/purchase/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/rejection-item/[type]/[id]",
      "regex": "^/api/rejection\\-item/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtype": "nxtPtype",
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/rejection\\-item/(?<nxtPtype>[^/]+?)/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/sales/[id]",
      "regex": "^/api/sales/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/sales/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/stock-ledger/[id]",

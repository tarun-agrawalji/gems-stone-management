{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/page.js"
    ],
    "/(app)/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/layout.js"
    ],
    "/(app)/dashboard/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/dashboard/page.js"
    ],
    "/api/auth/[...nextauth]/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/auth/[...nextauth]/route.js"
    ],
    "/api/dashboard/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/dashboard/route.js"
    ],
    "/(app)/rejection/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/rejection/page.js"
    ],
    "/api/rejection/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/rejection/route.js"
    ],
    "/(app)/rejection/[type]/[id]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/rejection/[type]/[id]/page.js"
    ],
    "/api/rejection-item/[type]/[id]/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/rejection-item/[type]/[id]/route.js"
    ],
    "/(app)/purchase/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/purchase/page.js"
    ],
    "/api/purchase/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/purchase/route.js"
    ],
    "/(app)/purchase/[id]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(app)/purchase/[id]/page.js"
    ],
    "/api/purchase/[id]/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/purchase/[id]/route.js"
    ]
  }
}